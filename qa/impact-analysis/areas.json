{
  "_comment": "Maps glob-style path patterns to affected test modules. Order matters: more specific patterns first.",

  "_deviceMatrix": {
    "_comment": "Defines which real devices/OS combos are required per platform token. Used to build the Device Matrix section.",
    "Web": {
      "required": ["Chrome/macOS", "Safari/macOS"],
      "recommended": ["Chrome/Windows", "Firefox/macOS"],
      "note": "Primary browser is Chrome; Safari matters for crypto APIs and clipboard"
    },
    "Desktop": {
      "required": ["macOS", "Windows"],
      "recommended": ["Linux (AppImage)"],
      "note": "Electron IPC, keychain (keytar), and tray behaviour differ between macOS and Windows"
    },
    "Extension": {
      "required": ["Chrome MV3", "Firefox MV2"],
      "recommended": [],
      "note": "Chrome ships MV3 (service worker), Firefox ships MV2 (background page) — background lifecycle differs"
    },
    "Mobile": {
      "required": ["iOS (iPhone)"],
      "recommended": ["Android", "iPad (tablet layout)"],
      "note": "Capacitor bridge, WKWebView clipboard, and biometry differ on iOS vs Android"
    },
    "TWA": {
      "required": ["Android Telegram"],
      "recommended": ["iOS Telegram"],
      "note": "TMA JS SDK behaves differently on Android vs iOS Telegram clients"
    }
  },

  "patterns": [
    {
      "pattern": ".github/**",
      "modules": ["_IGNORE_"],
      "platformScope": "Shared",
      "note": "CI/CD workflows and issue templates — no functional test impact"
    },
    {
      "pattern": "scripts/**",
      "modules": ["_IGNORE_"],
      "platformScope": "Shared",
      "note": "Build and release scripts — no functional test impact"
    },
    {
      "pattern": "turbo.json",
      "modules": ["_IGNORE_"],
      "platformScope": "Shared",
      "note": "Turborepo config — no functional test impact"
    },
    {
      "pattern": "yarn.lock",
      "modules": ["_IGNORE_"],
      "platformScope": "Shared",
      "note": "Dependency lockfile — no functional test impact"
    },
    {
      "pattern": "package.json",
      "modules": ["_IGNORE_"],
      "platformScope": "Shared",
      "note": "Root package.json — no functional test impact"
    },
    {
      "pattern": "*.md",
      "modules": ["_IGNORE_"],
      "platformScope": "Shared",
      "note": "Documentation files — no functional test impact"
    },
    {
      "pattern": ".eslintignore",
      "modules": ["_IGNORE_"],
      "platformScope": "Shared",
      "note": "Linter config — no functional test impact"
    },
    {
